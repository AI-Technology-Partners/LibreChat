# ─────────────────────────────────────────────────────────────────────────────
# Database connection – replace with your full MongoDB URI.
# Example:
#   mongodb://librechat:password@hostname:27017/LibreChat?retryWrites=false&directConnection=true
MONGO_URI=mongodb://{cosmos-account}:{cosmos-key}@{cosmos-account}.cosmos.azure.com:10255/?ssl=true&retrywrites=false&replicaSet=globaldb&maxIdleTimeMS=120000&appName=@{cosmos-account}2@

# ─────────────────────────────────────────────────────────────────────────────
# Google API configuration
GOOGLE_KEY=${GOOGLE_API_KEY}          # set GOOGLE_API_KEY elsewhere
GOOGLE_MODELS=gemini-2.5-pro-exp-03-25,gemini-2.0-flash-exp,gemini-2.0-flash-thinking-exp-1219

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI API configuration
OPENAI_API_KEY=${OPENAI_API_KEY}      # set OPENAI_API_KEY elsewhere
RAG_OPENAI_API_KEY=${OPENAI_API_KEY}

# RAG service endpoint
RAG_API_URL=https://${RAG_API_APP_NAME}.${CONTAINER_APP_ENV_DOMAIN}

OPENAI_MODELS=o1,o1-mini,gpt-4o-mini,gpt-4o-search-preview,o3-mini,o3,o4-mini

# ─────────────────────────────────────────────────────────────────────────────
# UI customization
CUSTOM_FOOTER="Provided by AITP"
HELP_AND_FAQ_URL=https://librechat.ai

# ─────────────────────────────────────────────────────────────────────────────
# Application feature flags
APP_TITLE="Enterprise GPT"
ALLOW_REGISTRATION=false
ALLOW_REGISTRATION_WITH_SOCIAL_ACCOUNTS=true
ALLOW_SOCIAL_LOGIN=true
ALLOW_EMAIL_LOGIN=false
ALLOW_UNVERIFIED_EMAIL_LOGIN=false

# ─────────────────────────────────────────────────────────────────────────────
# Azure Entra/AD (OpenID Connect)
OPENID_CLIENT_ID=
OPENID_CLIENT_SECRET=
OPENID_ISSUER=https://login.microsoftonline.com/e2851701-2a44-42bd-bbb5-804f3be2be4b/v2.0/
OPENID_SESSION_SECRET=
OPENID_SCOPE="openid profile email"  # DO NOT CHANGE

# ─────────────────────────────────────────────────────────────────────────────
# Domain and callback settings
DOMAIN_CLIENT=https://${LIBRECHAT_APP_NAME}.${CONTAINER_APP_ENV_DOMAIN}
DOMAIN_SERVER=https://${LIBRECHAT_APP_NAME}.${CONTAINER_APP_ENV_DOMAIN}
OPENID_CALLBACK_URL=/oauth/openid/callback

# ─────────────────────────────────────────────────────────────────────────────
# Enabled backend endpoints
ENDPOINTS=agents,openAI,google,azureOpenAI

 